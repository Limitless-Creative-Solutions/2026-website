{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "admin", "agent"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "Agency service offering.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "basePrice": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["title", "description"]
    },
    "Project": {
      "title": "Project",
      "description": "A client project being handled by the agency.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["discovery", "engineering", "qa", "launched"] },
        "progress": { "type": "integer" },
        "startDate": { "type": "string", "format": "date-time" },
        "launchDate": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title", "status"]
    },
    "Template": {
      "title": "Template",
      "description": "A marketplace template available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "demoUrl": { "type": "string" },
        "previewUrl": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A financial transaction recorded in the system.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "provider": { "type": "string", "enum": ["stripe", "payhere"] },
        "providerRef": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential client submission.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "projectDescription": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "qualified", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles restricted to owners and admins."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Public agency services."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Client projects where access is restricted to the specific client or admin."
    },
    "/templates/{templateId}": {
      "schema": "Template",
      "description": "Public marketplace templates."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Private transaction records."
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "CRM leads accessible only to admins."
    }
  }
}
